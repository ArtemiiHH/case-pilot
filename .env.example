# PostgreSQL connection string
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/casepilot"

# Express session secret — use a long random string in production
SESSION_SECRET="change-me-to-a-long-random-string"

# URL of the frontend (used for CORS and email links)
CLIENT_URL="http://localhost:5173"

# Resend API key — obtain from resend.com
RESEND_API_KEY="re_..."

# Sending address for client emails — must be on a domain verified with Resend.
# The firm's name is used as the display name; this address is just the envelope sender.
RESEND_FROM_EMAIL="updates@yourdomain.com"

# Node environment
NODE_ENV="development"
